@model PersonalLibrary.Models.Book
@{ ViewData["Title"] = "Додати книгу"; }

<h1 class="mb-4">Додати книгу</h1>

<form asp-action="Create" method="post" class="card p-4 shadow-sm">
    <div class="row">
        <div class="col-md-6 border-end">
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Author" class="form-label fw-bold"></label>
                <input asp-for="Author" class="form-control" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Year" class="form-label fw-bold"></label>
                    <input asp-for="Year" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PageCount" class="form-label fw-bold"></label>
                    <input asp-for="PageCount" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Publisher" class="form-label fw-bold"></label>
                    <input asp-for="Publisher" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ISBN" class="form-label fw-bold"></label>
                    <input asp-for="ISBN" class="form-control" placeholder="978-..." />
                    <span asp-validation-for="ISBN" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="CoverType" class="form-label fw-bold"></label>
                <input asp-for="CoverType" class="form-control" placeholder="Тверда, м'яка..." />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Розділ (Жанр)</label>
                <select asp-for="Section" class="form-select">
                    <option value="">-- Оберіть розділ --</option>
                    <option value="Белетристика (Художня література)">Белетристика (Художня література)</option>
                    <option value="Спеціальна література">Спеціальна література</option>
                    <option value="Хобі">Хобі</option>
                    <option value="Домашнє господарство">Домашнє господарство</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Tags" class="form-label fw-bold"></label>
                <input asp-for="Tags" class="form-control" placeholder="Python, детектив..." />
            </div>
            <div class="mb-3">
                <label asp-for="Origin" class="form-label fw-bold"></label>
                <select asp-for="Origin" class="form-select">
                    <option value="Куплено">Куплено</option>
                    <option value="Подаровано">Подаровано</option>
                </select>
            </div>
            <input type="hidden" asp-for="AvailabilityStatus" value="Вдома" />
            <input type="hidden" asp-for="ReadStatus" value="В планах" />
            <input type="hidden" asp-for="DateAdded" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-lg px-5">Додати книгу</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg px-4 ms-2">Скасувати</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}