@model IEnumerable<PersonalLibrary.Models.Book>

@{
    ViewData["Title"] = "Моя бібліотека";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Моя бібліотека</h1>
    <a asp-action="Create" class="btn btn-primary">Додати новий запис</a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Пошук за назвою, автором або тегом..." />
                <button type="submit" class="btn btn-outline-primary">Знайти</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Розділ / Теги</th>
            <th>Прочитання</th>
            <th>Наявність</th>
            <th>Боржник</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-3">Записів не знайдено.</td></tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">
                        @item.Title
                        @if(item.IsWishlist) { <span class="badge bg-warning text-dark ms-1">Wishlist</span> }
                    </td>
                    <td>@item.Author</td>
                    <td>
                        <span class="badge bg-info text-dark">@item.Section</span>
                        <br/><small class="text-muted">@item.Tags</small>
                    </td>
                    <td>
                        @if (item.ReadStatus == "Прочитано") { <span class="badge bg-success">Прочитано</span> }
                        else if (item.ReadStatus == "В процесі") { <span class="badge bg-warning text-dark">В процесі</span> }
                        else if (item.ReadStatus == "В планах") { <span class="badge bg-secondary">В планах</span> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td>
                        @if (item.AvailabilityStatus == "Вдома") { <span class="text-success fw-bold">Вдома</span> }
                        else if (item.AvailabilityStatus == "Видана на руки") { <span class="text-danger fw-bold">Видана</span> }
                        else if (item.AvailabilityStatus == "Архів") { <span class="text-muted">Архів</span> }
                        else { <span>@item.AvailabilityStatus</span> }
                    </td>
                    <td>@(string.IsNullOrEmpty(item.BorrowerName) ? "—" : item.BorrowerName)</td>
                    <td>
                        <div class="d-flex">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white me-1">Деталі</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Редаг.</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити?');">
                                <button type="submit" class="btn btn-sm btn-danger">Видал.</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>