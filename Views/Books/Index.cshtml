@model IEnumerable<PersonalLibrary.Models.Book>

@{
    ViewData["Title"] = ViewBag.IsWishlist ? "Мій Wishlist" : "Моя бібліотека";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@(ViewBag.IsWishlist ? "🛒 Список бажаного (Wishlist)" : "📚 Моя бібліотека")</h1>
    <a asp-action="Create" class="btn btn-primary">Додати книгу</a>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(ViewBag.IsWishlist ? "" : "active fw-bold")" asp-action="Index" asp-route-isWishlist="false">Основна бібліотека</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.IsWishlist ? "active fw-bold text-warning" : "")" asp-action="Index" asp-route-isWishlist="true">Wishlist</a>
    </li>
</ul>

<div class="card mb-4 p-3 bg-light border-0 shadow-sm">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <input type="hidden" name="isWishlist" value="@(ViewBag.IsWishlist.ToString().ToLower())" />
        
        <div class="col-md-4">
            <label class="form-label fw-bold">Пошук (Назва, Автор, Тег)</label>
            <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Введіть текст..." />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Розділ</label>
            <select name="sectionFilter" class="form-select">
                <option value="">-- Всі розділи --</option>
                <option value="Спеціальна література" selected="@(ViewBag.CurrentSection == "Спеціальна література")">Спеціальна література</option>
                <option value="Хобі" selected="@(ViewBag.CurrentSection == "Хобі")">Хобі</option>
                <option value="Домашнє господарство" selected="@(ViewBag.CurrentSection == "Домашнє господарство")">Домашнє господарство</option>
                <option value="Белетристика" selected="@(ViewBag.CurrentSection == "Белетристика")">Белетристика</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Статус</label>
            <select name="statusFilter" class="form-select">
                <option value="">-- Всі статуси --</option>
                <option value="Прочитано" selected="@(ViewBag.CurrentStatus == "Прочитано")">Прочитано</option>
                <option value="В процесі" selected="@(ViewBag.CurrentStatus == "В процесі")">В процесі</option>
                <option value="В планах" selected="@(ViewBag.CurrentStatus == "В планах")">В планах</option>
            </select>
        </div>
        <div class="col-md-2 d-flex flex-column">
            <button type="submit" class="btn btn-primary mb-2">Фільтрувати</button>
            <a asp-action="Index" asp-route-isWishlist="@ViewBag.IsWishlist" class="btn btn-outline-secondary">Скинути</a>
        </div>
    </form>
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Розділ / Теги</th>
            <th>Оцінка</th>
            <th>Наявність</th>
            <th>Трекінг Боржників</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-4">Записів не знайдено.</td></tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">
                        @item.Title
                        @if(ViewBag.IsWishlist && !string.IsNullOrEmpty(item.ShopLink)) 
                        { 
                            <br/><a href="@item.ShopLink" target="_blank" class="badge bg-primary text-decoration-none mt-1">Купити в магазині</a> 
                        }
                    </td>
                    <td>@item.Author</td>
                    <td>
                        <span class="badge bg-info text-dark">@item.Section</span>
                        <br/><small class="text-muted">@item.Tags</small>
                    </td>
                    <td>
                        @if (item.ReadStatus == "Прочитано") { <span class="badge bg-success mb-1">Прочитано</span><br/> }
                        else if (item.ReadStatus == "В процесі") { <span class="badge bg-warning text-dark mb-1">В процесі</span><br/> }
                        else if (item.ReadStatus == "В планах") { <span class="badge bg-secondary mb-1">В планах</span><br/> }
                        
                        @if (item.PersonalRating.HasValue) { <strong>@item.PersonalRating / 10</strong> }
                    </td>
                    <td>
                        @if (item.AvailabilityStatus == "Вдома") { <span class="text-success fw-bold">Вдома</span> }
                        else if (item.AvailabilityStatus == "Видана на руки") { <span class="text-danger fw-bold">Видана</span> }
                        else if (item.AvailabilityStatus == "Архів") { <span class="text-muted">Архів</span> }
                        else { <span>@item.AvailabilityStatus</span> }
                    </td>
                    
                    <td>
                        @if (item.AvailabilityStatus == "Видана на руки" && !string.IsNullOrEmpty(item.BorrowerName))
                        {
                            <strong>@item.BorrowerName</strong><br/>
                            if (item.ExpectedReturnDate.HasValue)
                            {
                                var daysLeft = (item.ExpectedReturnDate.Value - DateTime.Now.Date).Days;
                                if (daysLeft < 0)
                                {
                                    <span class="badge bg-danger mt-1">Прострочено на @Math.Abs(daysLeft) днів!</span>
                                }
                                else if (daysLeft == 0)
                                {
                                    <span class="badge bg-warning text-dark mt-1">Повернути сьогодні!</span>
                                }
                                else
                                {
                                    <small class="text-muted">До повернення: @daysLeft днів</small>
                                }
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    
                   <td>
                     <div class="d-flex flex-column gap-1">
       
                       <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Деталі</a>
        
                       @if (item.AvailabilityStatus == "Вдома")
                       {
                        <button type="button" class="btn btn-sm btn-primary" 
                          data-bs-toggle="modal" 
                          data-bs-target="#borrowModal" 
                          data-id="@item.Id">
                          Видати
                        </button>
                       }
        
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редаг.</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити?');">
                        <button type="submit" class="btn btn-sm btn-danger w-100">Видал.</button>
                      </form>
                    </div>
                 </td>
             </tr>
            }
        }
    </tbody>
</table>

<div class="modal fade" id="borrowModal" tabindex="-1" aria-labelledby="borrowModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="borrowModalLabel">Видача книги</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form asp-action="Edit" method="post">
        <div class="modal-body">
            <input type="hidden" name="Id" id="modalBookId" />
            
            <div class="mb-3">
                <label class="form-label fw-bold">Ім'я боржника</label>
                <input name="BorrowerName" class="form-control" placeholder="Іван Іванов" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Контакти (телефон/Telegram)</label>
                <input name="BorrowerContact" class="form-control" placeholder="@username або +380..." />
            </div>
            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Дата видачі</label>
                    <input name="BorrowDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Очікуване повернення</label>
                    <input name="ExpectedReturnDate" type="date" class="form-control" required />
                </div>
            </div>
            <input type="hidden" name="AvailabilityStatus" value="Видана на руки" />
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
            <button type="submit" class="btn btn-danger">Підтвердити видачу</button>
        </div>
      </form>
    </div>
  </div>
</div>


<script>
    var borrowModal = document.getElementById('borrowModal');
    borrowModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var bookId = button.getAttribute('data-id');
        var inputId = borrowModal.querySelector('#modalBookId');
        inputId.value = bookId;
    });
</script>