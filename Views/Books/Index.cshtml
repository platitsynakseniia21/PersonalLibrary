@model IEnumerable<PersonalLibrary.Models.Book>

@{
    ViewData["Title"] = "Моя бібліотека";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Моя бібліотека</h1>
    <a asp-action="Create" class="btn btn-primary">Додати нову книгу</a>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Пошук за назвою або автором..." />
                <button type="submit" class="btn btn-outline-primary">Знайти</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Розділ</th>
            <th>Статус</th>
            <th>В наявності</th>
            <th>Боржник</th>
            <th>Оцінка</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="8" class="text-center text-muted py-3">Книг не знайдено за цим запитом.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.Author</td>
                    <td><span class="badge bg-info text-dark">@item.Section</span></td>
                    <td>
                        @if (item.ReadStatus == "Прочитано")
                        {
                            <span class="badge bg-success">Прочитано</span>
                        }
                        else if (item.ReadStatus == "В процесі")
                        {
                            <span class="badge bg-warning text-dark">В процесі</span>
                        }
                        else if (item.ReadStatus == "В планах")
                        {
                            <span class="badge bg-secondary">В планах</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@(item.IsAvailable ? "Так" : "Ні")</td>
                    <td>@(string.IsNullOrEmpty(item.BorrowerName) ? "—" : item.BorrowerName)</td>
                    <td>@(item.PersonalRating.HasValue ? item.PersonalRating + "/10" : "—")</td>
                    <td>
                        <div class="d-flex">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">Редагувати</a>
                            
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю книгу?');">
                                <button type="submit" class="btn btn-sm btn-danger">Видалити</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>