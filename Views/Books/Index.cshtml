@model IEnumerable<PersonalLibrary.Models.Book>

@{
    ViewData["Title"] = "Моя бібліотека";
}

<div class="text-center mb-4">
    <h1 class="display-4">Моя бібліотека</h1>
    <p class="lead">Тут зберігаються всі ваші улюблені книги</p>
</div>

<p>
    <a class="btn btn-primary" asp-controller="Books" asp-action="Create">Додати нову книгу</a>
</p>

<div class="row mt-4 mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Пошук за назвою або автором..." />
                <button type="submit" class="btn btn-outline-primary">Знайти</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Розділ</th>
            <th>В наявності</th>
            <th>Оцінка</th>
            <th>Дії</th> </tr>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Ваша бібліотека поки що порожня. Додайте першу книгу!</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Title</td>
                    <td>@item.Author</td>
                    <td><span class="badge bg-info text-dark">@item.Section</span></td>
                    <td>@(item.IsAvailable ? "Так" : "Ні")</td>
                    <td>@(item.PersonalRating != null ? item.PersonalRating + "/10" : "-")</td>
                    
                   <td class="d-flex">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">Редагувати</a>
                        
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю книгу?');">
                            <button type="submit" class="btn btn-sm btn-danger">Видалити</button>
                        </form>
                    </td>
             
                </tr>
            }
        }
    </tbody>
</table>