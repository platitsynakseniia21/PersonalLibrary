@model IEnumerable<PersonalLibrary.Models.Book>

@{
    ViewData["Title"] = ViewBag.IsWishlist ? "Мій Wishlist" : "Моя бібліотека";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@(ViewBag.IsWishlist ? "🛒 Список бажаного (Wishlist)" : "📚 Моя бібліотека")</h1>
    <a asp-action="Create" class="btn btn-primary">Додати книгу</a>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(ViewBag.IsWishlist ? "" : "active fw-bold")" asp-action="Index" asp-route-isWishlist="false">Основна бібліотека</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.IsWishlist ? "active fw-bold text-warning" : "")" asp-action="Index" asp-route-isWishlist="true">Wishlist</a>
    </li>
</ul>

<div class="card mb-4 p-3 bg-light border-0 shadow-sm">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <input type="hidden" name="isWishlist" value="@(ViewBag.IsWishlist.ToString().ToLower())" />
        
        <div class="col-md-4">
            <label class="form-label fw-bold">Пошук (Назва, Автор, Тег)</label>
            <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Введіть текст..." />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Розділ</label>
            <select name="sectionFilter" class="form-select">
                 <option value="">-- Всі розділи --</option>
                 <option value="Любовні романи" selected="@(ViewBag.CurrentSection == "Любовні романи")">Любовні романи</option>
                 <option value="Трилери" selected="@(ViewBag.CurrentSection == "Трилери")">Трилери</option>
                 <option value="Детективи" selected="@(ViewBag.CurrentSection == "Детективи")">Детективи</option>
                 <option value="Фентезі" selected="@(ViewBag.CurrentSection == "Фентезі")">Фентезі</option>
                 <option value="Наукова фантастика" selected="@(ViewBag.CurrentSection == "Наукова фантастика")">Наукова фантастика</option>
                 <option value="Реалізм" selected="@(ViewBag.CurrentSection == "Реалізм")">Реалізм</option>
                 <option value="Містика" selected="@(ViewBag.CurrentSection == "Містика")">Містика</option>
                 <option value="Драма" selected="@(ViewBag.CurrentSection == "Драма")">Драма</option>
                 <option value="Пригодницька література" selected="@(ViewBag.CurrentSection == "Пригодницька література")">Пригодницька література</option>
                 <option value="Трагедія" selected="@(ViewBag.CurrentSection == "Трагедія")">Трагедія</option>
                 <option value="Комедія" selected="@(ViewBag.CurrentSection == "Комедія")">Комедія</option>
                 <option value="Дарк-романи" selected="@(ViewBag.CurrentSection == "Дарк-романи")">Дарк-романи</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Статус</label>
            <select name="statusFilter" class="form-select">
                <option value="">-- Всі статуси --</option>
                <option value="Прочитано" selected="@(ViewBag.CurrentStatus == "Прочитано")">Прочитано</option>
                <option value="В процесі" selected="@(ViewBag.CurrentStatus == "В процесі")">В процесі</option>
                <option value="В планах" selected="@(ViewBag.CurrentStatus == "В планах")">В планах</option>
            </select>
        </div>
        <div class="col-md-2 d-flex flex-column">
            <button type="submit" class="btn btn-primary mb-2">Фільтрувати</button>
            <a asp-action="Index" asp-route-isWishlist="@ViewBag.IsWishlist" class="btn btn-outline-secondary">Скинути</a>
        </div>
    </form>
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Розділ / Теги</th>
            <th>Статус</th>
            <th>Оцінка</th>
            <th>Наявність</th>
            <th>Трекінг Боржників</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
       @foreach (var item in Model) {
    <tr>
        <td class="fw-bold">@item.Title</td>
        <td>@item.Author</td>
        <td>
            <span class="badge bg-info text-dark">@item.Section</span>
            <br/><small class="text-muted">@item.Tags</small>
        </td>
        <td>
            @if(item.ReadStatus == "Прочитано") { <span class="badge bg-success">Прочитано</span> }
            else if(item.ReadStatus == "В процесі") { <span class="badge bg-warning text-dark">В процесі</span> }
            else { <span class="badge bg-secondary">В планах</span> }
        </td>
        <td><strong>@(item.PersonalRating ?? 0) / 10</strong></td>
        
        <td>
            @if(item.AvailabilityStatus == "Вдома") { 
                <span class="text-success fw-bold">Так</span> 
            }
            else if(item.AvailabilityStatus == "Відсутня") { 
                <span class="text-secondary fw-bold">Немає</span> 
            }
            else { 
                <span class="text-danger fw-bold">Видана</span>
                @if (item.ExpectedReturnDate < DateTime.Today) {
                    <br/><span class="badge bg-danger">Прострочено!</span> 
                }
            }
       </td>

        <td>
            @if(item.AvailabilityStatus == "Видана на руки") {
                <strong>@item.BorrowerName</strong><br/>
                <small class="text-muted">Повернути до: @item.ExpectedReturnDate?.ToString("dd.MM")</small>
            } else { <span>—</span> }
        </td>
        <td>
            <div class="d-flex flex-column gap-1">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Деталі</a>
                
                @if (item.AvailabilityStatus == "Вдома" && !item.IsWishlist) {
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#borrowModal" data-id="@item.Id">Видати</button>
                }
                else if (item.AvailabilityStatus == "Видана на руки") {
                    <form asp-action="ReturnBook" asp-route-id="@item.Id" method="post">
                        <button type="submit" class="btn btn-sm btn-success w-100">Повернути</button>
                    </form>
                }

                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редаг.</a>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити?');">
                    <button type="submit" class="btn btn-sm btn-danger w-100">Видал.</button>
                </form>
            </div>
        </td>
    </tr>
    }
    </tbody>
</table>

<div class="modal fade" id="borrowModal" tabindex="-1" aria-labelledby="borrowModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="borrowModalLabel">Видача книги</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form asp-action="IssueBook" method="post">
        <div class="modal-body">
            <input type="hidden" name="Id" id="modalBookId" />
            
            <div class="mb-3">
                <label class="form-label fw-bold">Ім'я боржника</label>
                <input type="text" name="BorrowerName" class="form-control" 
                           data-val="true" 
                           data-val-required="Помилка: обов'язково введіть ім'я!" />
                <span class="text-danger fw-bold field-validation-valid" data-valmsg-for="BorrowerName" data-valmsg-replace="true"></span>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Контакти (телефон/Telegram)</label>
                <input type="text" name="BorrowerContact" class="form-control" 
                           data-val="true" 
                           data-val-required="Помилка: обов'язково вкажіть контакти!" />
                <span class="text-danger fw-bold field-validation-valid" data-valmsg-for="BorrowerContact" data-valmsg-replace="true"></span>
            </div>
            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Дата видачі</label>
                    <input name="BorrowDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label fw-bold">Очікуване повернення</label>
                    <input name="ExpectedReturnDate" type="date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>
            </div>
            <input type="hidden" name="AvailabilityStatus" value="Видана на руки" />
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
            <button type="submit" class="btn btn-danger">Підтвердити видачу</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
    var borrowModal = document.getElementById('borrowModal');
    borrowModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var bookId = button.getAttribute('data-id');
        var inputId = borrowModal.querySelector('#modalBookId');
        inputId.value = bookId;
    });
</script>