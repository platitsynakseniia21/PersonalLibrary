@model PersonalLibrary.Models.Book
@{ ViewData["Title"] = "Редагувати запис"; }

<h1 class="mb-4">Редагувати запис у бібліотеці</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="DateAdded" />
    
    <div class="row">
        <div class="col-md-6 border-end">
            <h4 class="text-primary mb-3">1. Основні дані</h4>
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Author" class="form-label fw-bold"></label>
                <input asp-for="Author" class="form-control" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Year" class="form-label fw-bold"></label>
                    <input asp-for="Year" type="number" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PageCount" class="form-label fw-bold"></label>
                    <input asp-for="PageCount" type="number" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Publisher" class="form-label fw-bold"></label>
                    <input asp-for="Publisher" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ISBN" class="form-label fw-bold"></label>
                    <input asp-for="ISBN" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="CoverType" class="form-label fw-bold"></label>
                <input asp-for="CoverType" class="form-control" />
            </div>
        </div>

        <div class="col-md-6">
            <h4 class="text-primary mb-3">2. Категоризація та статус</h4>
            <div class="mb-3">
                <label asp-for="Section" class="form-label fw-bold"></label>
                <select asp-for="Section" class="form-select">
                    <option value="">-- Оберіть розділ --</option>
                    <option value="Спеціальна література">Спеціальна література</option>
                    <option value="Хобі">Хобі</option>
                    <option value="Домашнє господарство">Домашнє господарство</option>
                    <option value="Белетристика">Белетристика</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Tags" class="form-label fw-bold"></label>
                <input asp-for="Tags" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Origin" class="form-label fw-bold"></label>
                <select asp-for="Origin" class="form-select">
                    <option value="">-- Джерело появи --</option>
                    <option value="Куплено">Куплено</option>
                    <option value="Подаровано">Подаровано</option>
                    <option value="Успадковано">Успадковано</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="AvailabilityStatus" class="form-label fw-bold"></label>
                <select asp-for="AvailabilityStatus" class="form-select">
                    <option value="Вдома">Вдома</option>
                    <option value="Видана на руки">Видана на руки</option>
                    <option value="Втрачена">Втрачена</option>
                    <option value="Архів">Архів (Архівувати)</option>
                </select>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <div class="row">
        <div class="col-md-6 border-end">
            <h4 class="text-success mb-3">3. Особиста оцінка</h4>
            <div class="mb-3">
                <label asp-for="ReadStatus" class="form-label fw-bold"></label>
                <select asp-for="ReadStatus" class="form-select">
                    <option value="">-- Статус --</option>
                    <option value="Прочитано">Прочитано</option>
                    <option value="В процесі">В процесі</option>
                    <option value="В планах">В планах</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="PersonalRating" class="form-label fw-bold"></label>
                <input asp-for="PersonalRating" type="number" class="form-control" />
                <span asp-validation-for="PersonalRating" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Review" class="form-label fw-bold"></label>
                <textarea asp-for="Review" class="form-control" rows="4"></textarea>
            </div>
        </div>

        <div class="col-md-6">
            <h4 class="text-danger mb-3">4. Трекінг боржників</h4>
            <div class="mb-3">
                <label asp-for="BorrowerName" class="form-label fw-bold"></label>
                <input asp-for="BorrowerName" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="BorrowerContact" class="form-label fw-bold"></label>
                <input asp-for="BorrowerContact" class="form-control" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BorrowDate" class="form-label fw-bold"></label>
                    <input asp-for="BorrowDate" type="date" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ExpectedReturnDate" class="form-label fw-bold"></label>
                    <input asp-for="ExpectedReturnDate" type="date" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <div class="row mb-4">
        <div class="col-12 p-3 bg-light rounded border border-warning">
            <h4 class="text-warning mb-3">5. Wishlist (Список бажаного)</h4>
            <div class="form-check mb-3">
                <input asp-for="IsWishlist" class="form-check-input" style="transform: scale(1.5); margin-right: 10px;" />
                <label asp-for="IsWishlist" class="form-check-label fw-bold text-dark">
                    Це запис для Wishlist
                </label>
            </div>
            <div class="mb-2">
                <label asp-for="ShopLink" class="form-label fw-bold"></label>
                <input asp-for="ShopLink" class="form-control" />
            </div>
        </div>
    </div>

    <div class="mb-5">
        <button type="submit" class="btn btn-primary btn-lg me-2 px-5">Зберегти зміни</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg px-4">Скасувати</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}